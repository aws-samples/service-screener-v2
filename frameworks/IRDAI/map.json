  "metadata": {
    "originator": "IRDAI",
    "shortname": "IRDAI ICG",
    "fullname": "Insurance Regulatory and Development Authority of India (IRDAI) Information and Cyber Security Guidelines 2023 (Revised April 2026)",
    "description": "The IRDAI Information and Cyber Security Guidelines (April 2023, revised April 6, 2026) establish comprehensive cybersecurity requirements for all insurers, insurance intermediaries, brokers, TPAs, web aggregators, and insurance repositories operating in India. The April 2026 revision mandates quarterly ISRMC meetings, CISO independence, IT Steering Committee, post-quantum readiness, enhanced board accountability, and 30-day audit report submission. This framework maps AWS service configurations to IRDAI compliance requirements covering governance, data protection, access control, network security, monitoring, incident response, business continuity, outsourcing, and audit readiness.",
    "_": "https://www.irdai.gov.in/",
    "emptyCheckDefaultMsg": "<small><i>Please refer to the IRDAI Information and Cyber Security Guidelines 2023 (revised April 2026) for further details. Kindly provide evidence or artifacts demonstrating compliance with the respective control.</i></small>"
  },
